{
  "rewrites": [
    { "source": "/cotizar", "destination": "/cotizar.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/recetarios", "destination": "/recetarios.html" },
    { "source": "/compra-exitosa", "destination": "/compra-exitosa.html" },
    { "source": "/compra-fallida", "destination": "/compra-fallida.html" },
    { "source": "/compra-pendiente", "destination": "/compra-pendiente.html" }
  ],
  "functions": {
    "api/record_purchase.js":    { "memory": 512, "maxDuration": 30 },
    "api/create_preference.js":  { "memory": 256, "maxDuration": 15 },
    "api/bookings/create.js":    { "memory": 256, "maxDuration": 20 },
    "api/bookings/confirm.js":   { "memory": 256, "maxDuration": 20 },
    "api/bookings/reject.js":    { "memory": 256, "maxDuration": 15 },
    "api/whatsapp/webhook.js":   { "memory": 512, "maxDuration": 30 },
    "api/whatsapp/send.js":      { "memory": 256, "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://javotecocina.com" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
